# Model profile: google/gemma-4-26B-A4B-it (Gemma 4 MoE)
#
# Container: Docker Hub vllm/vllm-openai:gemma4 — NGC 26.03 does NOT have
#   native Gemma4 support (falls back to Transformers MoE path → crashes).
# Entrypoint: Docker Hub style — pass model name directly, no "vllm serve" prefix.
# Attention: omit --attention-backend (FlashInfer crashes on Gemma4 head_size).
# Block size: omit --block-size (Mamba cache alignment crash on hybrid arch).
# Weight format: BF16 (49 GB). Load time ~7 min on GB10.
# Capabilities: Multimodal (text + image), 256K native context.
#
# See MODEL-NOTES.md for full compatibility details.

# --- Container ---
VLLM_IMAGE=vllm/vllm-openai:gemma4
# Docker Hub images already have "vllm serve" as entrypoint — pass model only.
VLLM_SERVE_CMD=

# --- vLLM flags ---
# NO --attention-backend (FlashInfer head_size crash; vLLM auto-selects TRITON_ATTN)
# NO --block-size (Mamba cache alignment crash on hybrid architecture)
VLLM_EXTRA_ARGS="--enable-prefix-caching --kv-cache-dtype fp8 --enable-auto-tool-choice --tool-call-parser gemma4 --max-num-batched-tokens 4096 --max-num-seqs 64 --trust-remote-code"

# --- Recommended defaults (overridable by node.env) ---
PROFILE_DEFAULT_MAX_MODEL_LEN=131072
PROFILE_DEFAULT_GPU_MEM_UTIL=0.80
PROFILE_DEFAULT_TP_SIZE=1