# Model profile: nvidia/Qwen3-235B-A22B-FP4 (flagship)
#
# Container: NGC image — standard Qwen3 MoE architecture.
# Entrypoint: NGC style.
# Weight format: FP4 (125 GB). Fits on single GB10.
# Note: Untested with 26.03 container but likely works (standard Qwen3 MoE arch).
#
# See MODEL-NOTES.md for full compatibility details.

# --- Container ---
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.03-py3
VLLM_SERVE_CMD="vllm serve"

# --- vLLM flags ---
# Large MoE model — conservative batch settings, no block-size override
VLLM_EXTRA_ARGS="--enable-prefix-caching --attention-backend flashinfer --kv-cache-dtype fp8 --enable-auto-tool-choice --tool-call-parser qwen3_coder --max-num-seqs 8 --max-num-batched-tokens 4096 --trust-remote-code"

# --- Recommended defaults (overridable by node.env) ---
# Large model — conservative memory and context settings
PROFILE_DEFAULT_MAX_MODEL_LEN=32768
PROFILE_DEFAULT_GPU_MEM_UTIL=0.90
# Fits on single node at FP4 but tight
PROFILE_DEFAULT_TP_SIZE=1