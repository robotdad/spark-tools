# Model profile: Qwen/Qwen3.6-35B-A3B-FP8 (Qwen 3.6 MoE)
#
# Container: NGC nvcr.io/nvidia/vllm:26.03-py3 — has native Qwen3_5Moe support.
# Entrypoint: NGC style — needs "vllm serve" prefix.
# Attention: FlashInfer works for Qwen 3.6.
# Block size: omit --block-size (hybrid Gated DeltaNet → Mamba cache alignment crash).
# Weight format: FP8 (35 GB). Load time ~5 min on GB10.
# Capabilities: Best agentic coding model in this size class, 262K context.
#
# See MODEL-NOTES.md for full compatibility details.

# --- Container ---
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.03-py3
# NGC images need explicit "vllm serve" command prefix.
VLLM_SERVE_CMD="vllm serve"

# --- vLLM flags ---
# FlashInfer works for Qwen 3.6 (unlike Gemma 4)
# NO --block-size (hybrid Gated DeltaNet: 3/4 linear attention + 1/4 full attention)
VLLM_EXTRA_ARGS="--enable-prefix-caching --attention-backend flashinfer --kv-cache-dtype fp8 --enable-auto-tool-choice --tool-call-parser qwen3_coder --max-num-seqs 32 --max-num-batched-tokens 4096 --trust-remote-code"

# --- Recommended defaults (overridable by node.env) ---
PROFILE_DEFAULT_MAX_MODEL_LEN=262144
PROFILE_DEFAULT_GPU_MEM_UTIL=0.90
PROFILE_DEFAULT_TP_SIZE=1