# Model profile: nvidia/Qwen3-14B-FP4 (previous default)
#
# Container: Any NGC image works — older model with broad support.
# Entrypoint: NGC style.
# Attention: FlashInfer works fine (standard transformer, no hybrid layers).
# Block size: 128 works (no Mamba layers).
# Weight format: FP4 (10 GB). Fast load.
#
# See MODEL-NOTES.md for full compatibility details.

# --- Container ---
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.03-py3
VLLM_SERVE_CMD="vllm serve"

# --- vLLM flags ---
# Standard transformer — block-size 128 and FlashInfer both safe
VLLM_EXTRA_ARGS="--enable-prefix-caching --block-size 128 --attention-backend flashinfer --kv-cache-dtype fp8 --enable-auto-tool-choice --tool-call-parser qwen3_coder --max-num-seqs 16 --trust-remote-code"

# --- Recommended defaults (overridable by node.env) ---
PROFILE_DEFAULT_MAX_MODEL_LEN=131072
PROFILE_DEFAULT_GPU_MEM_UTIL=0.85
PROFILE_DEFAULT_TP_SIZE=1