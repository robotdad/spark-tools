#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
source "${SCRIPT_DIR}/../lib/spark-common.sh"

if [[ "${1:-}" == "-h" ]]; then
    cat <<'EOF'
Usage: spark-install-services [--mode MODE] [--dry-run] [--uninstall]

Install systemd service units for the spark inference stack.

Options:
  --mode MODE    Orchestration mode to install units for: swarm or ray.
                 Default: reads SPARK_MODE from cluster.env.
  --dry-run      Preview rendered unit files without writing anything (no sudo needed).
  --uninstall    Stop, disable, and remove all spark-* service units.

Preconditions: cluster.env must exist (run 'spark-init' first); sudo required except with --dry-run.

Run 'spark-install-services --help' for full details.
EOF
    exit 0
fi

if [[ "${1:-}" == "--help" ]]; then
    cat <<'EOF'
spark-install-services — install systemd service units for the spark inference stack

Generates systemd unit files from templates in the spark-tools systemd/ directory,
substituting live values (username, paths, IPs, interface names) into {{PLACEHOLDER}}
tokens, then writes the rendered units to /etc/systemd/system/ and reloads the daemon.

WHY: systemd units enable automatic service startup on boot, restart-on-failure
semantics, and clean shutdown of the Ray or Docker Swarm containers. Run this
command once per node after 'spark-init' to register the correct services for
your orchestration mode and node role.

Usage:
  spark-install-services [--mode MODE] [--dry-run] [--uninstall]

Options:
  --mode MODE    Orchestration mode to install services for:
                   swarm  — installs spark-swarm-stack.service on the manager
                            node (monad). dyad joins the swarm overlay network
                            and requires no unit of its own.
                   ray    — auto-detects node role by comparing $(hostname)
                            against SPARK_PRIMARY_HOST from cluster.env:
                              monad (head)   → spark-ray-head.service
                                               spark-ray-vllm.service
                              dyad (worker)  → spark-ray-worker.service
                 Default: SPARK_MODE read from ~/.config/spark-tools/cluster.env.

  --dry-run      Preview mode. Prints the fully-rendered unit file contents to
                 stdout without writing any files or running systemctl. Does not
                 require sudo. Safe to run at any time.

  --uninstall    Stop, disable, and remove all spark-* service units from
                 /etc/systemd/system/:
                   spark-swarm-stack  spark-ray-head
                   spark-ray-worker   spark-ray-vllm
                 Runs 'sudo systemctl daemon-reload' after removal. Combine
                 with --dry-run to preview which units would be removed.

Preconditions:
  - ~/.config/spark-tools/cluster.env must exist. Run 'spark-init' first.
  - sudo is required (units are written to /etc/systemd/system/).
  - --dry-run operates without sudo.

Template substitutions:
  Templates live in <spark-tools>/systemd/*.service.template.
  The following tokens are replaced at install time:
    {{USERNAME}}        current user (whoami)
    {{SPARK_TOOLS_DIR}} absolute path to the spark-tools repo
    {{COMPOSE_FILE}}    ~/docker-compose.yml
    {{QSFP_IFACE}}      SPARK_QSFP_IFACE from cluster.env
    {{HEAD_IP}}         IP on SPARK_QSFP_IFACE (falls back to first LAN IP)
    {{RAY_VLLM_IMAGE}}  SPARK_RAY_VLLM_IMAGE from cluster.env (or image default)
    {{PORT}}            SPARK_PORT from cluster.env (default: 8000)

Side effects (non-dry-run):
  - Unit file(s) written to /etc/systemd/system/<name>.service
  - 'sudo systemctl daemon-reload' is run automatically.
  - Services are NOT enabled or started — use the printed commands to do so.

Exit codes:
  0  Templates processed and units installed (or uninstalled) successfully.
  1  Unknown option, missing --mode value, invalid mode, or cluster.env absent.

Examples:
  # Preview rendered unit files without writing anything (no sudo needed):
  spark-install-services --dry-run

  # Install services for swarm mode (reads SPARK_MODE from cluster.env):
  spark-install-services

  # Explicitly install for ray mode (node role auto-detected from hostname):
  spark-install-services --mode ray

  # After ray install on monad — enable and start:
  sudo systemctl enable spark-ray-head spark-ray-vllm
  sudo systemctl start  spark-ray-head
  sudo systemctl start  spark-ray-vllm    # waits for Ray head to be ready

  # After swarm install on monad — enable and start:
  sudo systemctl enable --now spark-swarm-stack

  # Remove all spark service units:
  spark-install-services --uninstall

See also:
  spark-init              create cluster.env and model.env (prerequisite)
  spark-install-extras    add PATH symlinks, MOTD, and auth proxy
  spark-status            verify services are healthy after startup
  spark-help              full command reference
  install.sh              unified one-shot installer (preferred for first installs)

Run 'spark-install-services -h' for short help.
EOF
    exit 0
fi

spark_load_config

DRY_RUN=false
UNINSTALL=false
INSTALL_MODE="$SPARK_MODE"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --mode) shift; INSTALL_MODE="${1:-}"; [[ -z "$INSTALL_MODE" ]] && spark_die "--mode requires a value" ;;
        --dry-run) DRY_RUN=true ;;
        --uninstall) UNINSTALL=true ;;
        *) spark_die "Unknown option: $1" ;;
    esac
    shift
done

SYSTEMD_DIR="/etc/systemd/system"
TEMPLATES_DIR="${SPARK_TOOLS_DIR}/systemd"
USERNAME="$(whoami)"

# Detect HEAD_IP on QSFP
HEAD_IP=$(ip -4 addr show "$SPARK_QSFP_IFACE" 2>/dev/null | grep -oP 'inet \K[\d.]+' || hostname -I | awk '{print $1}')

# Template substitution function
process_template() {
    local template="$1"
    sed \
        -e "s|{{USERNAME}}|${USERNAME}|g" \
        -e "s|{{SPARK_TOOLS_DIR}}|${SPARK_TOOLS_DIR}|g" \
        -e "s|{{COMPOSE_FILE}}|${HOME}/docker-compose.yml|g" \
        -e "s|{{QSFP_IFACE}}|${SPARK_QSFP_IFACE}|g" \
        -e "s|{{HEAD_IP}}|${HEAD_IP}|g" \
        -e "s|{{RAY_VLLM_IMAGE}}|${SPARK_RAY_VLLM_IMAGE:-scitrera/dgx-spark-vllm:0.15.1-t5}|g" \
        -e "s|{{PORT}}|${SPARK_PORT:-8000}|g" \
        "$template"
}

if [[ "$UNINSTALL" == true ]]; then
    echo "Uninstalling spark services..."
    for svc in spark-swarm-stack spark-ray-head spark-ray-worker spark-ray-vllm; do
        if [[ -f "$SYSTEMD_DIR/${svc}.service" ]]; then
            echo "  Disabling and removing ${svc}.service"
            if [[ "$DRY_RUN" != true ]]; then
                sudo systemctl disable "${svc}.service" 2>/dev/null || true
                sudo systemctl stop "${svc}.service" 2>/dev/null || true
                sudo rm -f "$SYSTEMD_DIR/${svc}.service"
            fi
        fi
    done
    [[ "$DRY_RUN" != true ]] && sudo systemctl daemon-reload
    echo "Done."
    exit 0
fi

echo "=== Installing Systemd Services (mode: ${INSTALL_MODE}) ==="
echo ""

case "$INSTALL_MODE" in
    swarm)
        TEMPLATES=("spark-swarm-stack.service.template")
        ;;
    ray)
        # Determine which node we're on
        if [[ "$(hostname)" == "$SPARK_PRIMARY_HOST" || "$(hostname)" == "$(echo "$SPARK_PRIMARY_HOST" | cut -d. -f1)" ]]; then
            TEMPLATES=("spark-ray-head.service.template" "spark-ray-vllm.service.template")
            echo "Detected: HEAD node (${SPARK_PRIMARY_HOST})"
        else
            TEMPLATES=("spark-ray-worker.service.template")
            echo "Detected: WORKER node"
        fi
        ;;
    *)
        spark_die "Unknown mode: $INSTALL_MODE"
        ;;
esac

for tmpl in "${TEMPLATES[@]}"; do
    SVC_NAME="${tmpl%.template}"
    TMPL_PATH="${TEMPLATES_DIR}/${tmpl}"

    if [[ ! -f "$TMPL_PATH" ]]; then
        spark_warn "Template not found: $TMPL_PATH (skipping)"
        continue
    fi

    echo "Processing: $tmpl → $SVC_NAME"

    if [[ "$DRY_RUN" == true ]]; then
        echo "--- BEGIN $SVC_NAME ---"
        process_template "$TMPL_PATH"
        echo "--- END $SVC_NAME ---"
        echo ""
    else
        process_template "$TMPL_PATH" | sudo tee "$SYSTEMD_DIR/$SVC_NAME" > /dev/null
        echo "  Installed: $SYSTEMD_DIR/$SVC_NAME"
    fi
done

if [[ "$DRY_RUN" != true ]]; then
    sudo systemctl daemon-reload
    echo ""
    echo "Services installed. Enable with:"
    for tmpl in "${TEMPLATES[@]}"; do
        SVC_NAME="${tmpl%.template}"
        echo "  sudo systemctl enable ${SVC_NAME}"
    done
    echo ""
    echo "Start with:"
    for tmpl in "${TEMPLATES[@]}"; do
        SVC_NAME="${tmpl%.template}"
        echo "  sudo systemctl start ${SVC_NAME}"
    done
fi
