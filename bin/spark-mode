#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
source "${SCRIPT_DIR}/../lib/spark-common.sh"

#=============================================================================
# spark-mode — orchestration + topology switcher
#=============================================================================
# TWO independent concepts, one command:
#
#   ORCHESTRATION (updates cluster.env; no services touched):
#     spark-mode swarm [--engine trtllm|vllm]
#     spark-mode ray
#
#   TOPOLOGY (operational; starts/stops real services; requires sudo):
#     sudo spark-mode split     — two independent vLLM instances (TP=1/node)
#     sudo spark-mode cluster   — Ray TP=2 cluster across monad + dyad
#          spark-mode status    — show current topology + service states
#=============================================================================

# ─── Help ────────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "-h" ]]; then
    cat << 'SHORT'
Usage: spark-mode [swarm|ray [--engine ENGINE] | split | cluster | status]
View or switch cluster orchestration mode and deployment topology.

ORCHESTRATION (config only — no services touched, no sudo needed):
  swarm [--engine trtllm|vllm]  Switch to Docker Swarm + MPI orchestration
  ray                           Switch to Ray orchestration (vLLM only)

TOPOLOGY (live service ops):
  sudo spark-mode split         Two independent vLLM instances, TP=1 per node
  sudo spark-mode cluster       Ray TP=2 cluster sharded across monad + dyad
       spark-mode status        Show current topology and live service states
  --dry-run                      Preview what would change without modifying anything

  (no args)                     Show current configuration

Use 'spark-mode --help' for the extended reference (designed for AI agents like Amplifier).
SHORT
    exit 0
fi
if [[ "${1:-}" == "--help" ]]; then
    cat << 'EOF'
spark-mode — view or switch cluster orchestration mode and deployment topology

TWO INDEPENDENT CONCEPTS, ONE COMMAND
======================================
This command handles two separate concerns dispatched by the first argument:

  ORCHESTRATION (swarm, ray)
    Which scheduler manages the inference stack.
    Writes SPARK_MODE and SPARK_ENGINE to ~/.config/spark-tools/cluster.env.
    Does NOT touch running services — you must stop/restart them manually.
    No sudo required.

  TOPOLOGY (split, cluster, status)
    Physical arrangement of services across monad (primary) and dyad (worker).
    Operationally stops/starts real systemd services on both nodes.
    Uses SSH to reach dyad for remote operations.
    split and cluster require sudo (systemd unit installation needs root).
    status does not require sudo.

With no arguments: prints current configuration from cluster.env + model.env.

USAGE
=====
  spark-mode                           Show current configuration
  spark-mode swarm [--engine ENGINE]   Switch to Swarm orchestration (config only)
  spark-mode ray                       Switch to Ray orchestration (config only)
  sudo spark-mode split                Activate split topology (live service ops)
  sudo spark-mode cluster              Activate cluster topology (live service ops)
  spark-mode status                    Show topology and live service states

PRECONDITIONS
=============
For orchestration commands (swarm, ray):
  - spark-init must have been run; ~/.config/spark-tools/cluster.env must exist

For topology commands (split, cluster):
  - sudo access on monad (invoke as: sudo spark-mode split/cluster)
  - Passwordless SSH from monad to dyad as $SUDO_USER (the operator account)
  - dyad reachable at SPARK_SECONDARY_HOST (default: dyad)
  - For split: MODEL_NAME must be set in model.env
  - For split: model weights already downloaded on dyad at:
      ~/.cache/huggingface/hub/models--<Org>--<ModelName>/

ORCHESTRATION COMMANDS
======================
  swarm               Docker Swarm + MPI orchestration.
                      Supports both trtllm and vllm engines.
                      Required for TRT-LLM (MPI handles multi-node transport).

  ray                 Ray cluster orchestration.
                      Supports vllm engine only.
                      If --engine trtllm is also given, engine is silently
                      corrected to vllm with a warning (ray + trtllm is invalid).

  --engine ENGINE     Also change the inference engine. Values: trtllm, vllm.
                      Without this flag, the current engine is kept unchanged.

  --dry-run           Preview the intended changes without modifying cluster.env
                      or touching any services. Works with swarm, ray, split,
                      and cluster subcommands.

TOPOLOGY COMMANDS
=================
  split               Two independent vLLM instances, one per node (TP=1 each).
                      monad runs spark-vllm-standalone independently.
                      dyad  runs spark-vllm-standalone independently.
                      The proxy load-balances across both nodes.
                      Best for: high throughput / double request capacity when
                      the model fits in a single GB10's memory.

                      Performs 10 steps:
                        [1/12] SSH preflight — verify dyad is reachable
                        [2/12] Model cache check — verify model weights on dyad
                        [3/12] Stop Ray/Swarm services on monad (stop+disable)
                        [4/12] Stop Ray services on dyad (via SSH sudo)
                        [5/12] Remove stale containers on both nodes (docker rm -f)
                        [6/12] Install spark-vllm-standalone.service on monad
                               (rendered from systemd/ template with substituted vars)
                        [7/12] Install node.env on monad
                               (from ~/.config/spark-tools/node.env.monad, or
                                writes TP_SIZE=1 as fallback if file not found)
                        [8/12] Install spark-vllm-standalone.service on dyad
                               (piped via SSH sudo tee)
                        [11/12] Sync model.env + node.env to dyad
                               (node.env sourced from node.env.dyad, or TP_SIZE=1)
                       [12/12] Enable + start spark-vllm-standalone on both nodes;
                               restart spark-proxy; write "split" to topology file

  cluster             Ray TP=2 cluster: one model sharded across monad + dyad.
                      monad runs spark-ray-head + spark-ray-vllm (TP=2 driver).
                      dyad  runs spark-ray-worker (connects back to head IP).
                      GPU-to-GPU tensor traffic flows over QSFP (SPARK_QSFP_IFACE).
                      Best for: models too large for one node, or when lowest
                      single-request latency matters more than parallel throughput.

                      Performs 9 steps:
                        [1/9] Stop spark-vllm-standalone on monad (stop+disable)
                        [2/9] Stop spark-vllm-standalone on dyad (via SSH sudo)
                        [3/9] Remove stale containers on both nodes (docker rm -f)
                        [4/9] Remove per-node node.env overrides on both nodes
                        [5/9] Install spark-ray-head.service + spark-ray-vllm.service
                              on monad (rendered from systemd/ templates)
                        [6/9] Install spark-ray-worker.service on dyad
                              (piped via SSH sudo tee)
                        [7/9] daemon-reload; start spark-ray-head; wait 5s;
                              start spark-ray-worker on dyad; wait 10s for join
                        [8/9] Enable + start spark-ray-vllm on monad
                        [9/9] Restart spark-proxy; write "cluster" to topology file

  status              Show current topology and live systemd service states.
                      Reads ~/.config/spark-tools/topology for declared topology.
                      Default topology is "cluster" if the file does not exist.
                      SSHes to dyad to check its service states.
                      Does not require sudo.

                      In split topology, checks on each node:
                        spark-vllm-standalone
                      In cluster topology, checks:
                        monad: spark-ray-head, spark-ray-vllm
                        dyad:  spark-ray-worker
                      Always checks: spark-proxy (on monad)

TOPOLOGY FILE
=============
The active topology is persisted to:
  ~/.config/spark-tools/topology

Written by split/cluster on success. Contains "split" or "cluster".
If absent, "cluster" is assumed (the more complex/default configuration).

SERVICE TEMPLATES
=================
Systemd unit files are rendered from templates at install time:
  <spark-tools>/systemd/spark-vllm-standalone.service.template
  <spark-tools>/systemd/spark-ray-head.service.template
  <spark-tools>/systemd/spark-ray-vllm.service.template
  <spark-tools>/systemd/spark-ray-worker.service.template

Template variables substituted:
  {{USERNAME}} {{HEAD_IP}} {{QSFP_IFACE}} {{RAY_VLLM_IMAGE}} {{VLLM_IMAGE}} {{PORT}}

EXAMPLES
========
Show current configuration (no arguments):
  $ spark-mode
  Spark Tools Configuration
    Mode:      ray
    Engine:    vllm
    Primary:   monad
    Secondary: dyad
    QSFP:      enp1s0f0np0
    API Port:  8000
    Model:     nvidia/Qwen3-235B-A22B-FP4
    TP Size:   2
    Context:   32768
    GPU Mem:   0.85

Switch to Ray orchestration (config only, services not touched):
  $ spark-mode ray
  Switching: swarm+trtllm → ray+vllm
  WARNING: Ray mode does not support trtllm. Switching engine to vllm.
  Updated: /home/user/.config/spark-tools/cluster.env
  Note: vLLM uses port 8000 by default

  Current orchestration mode: ray + vllm

  If services are running, stop and restart them:
    spark-stop && spark-serve

Switch to Swarm + TRT-LLM (config only, services not touched):
  $ spark-mode swarm --engine trtllm
  Switching: ray+vllm → swarm+trtllm
  Updated: /home/user/.config/spark-tools/cluster.env
  Note: TRT-LLM uses port 8355 by default

  Current orchestration mode: swarm + trtllm

  If services are running, stop and restart them:
    spark-stop && spark-serve

Activate split topology (live — installs services, requires sudo):
  $ sudo spark-mode split
  Switching to SPLIT mode (two independent vLLM instances, TP=1 per node)...

  [1/12] Pre-flight: verifying SSH connectivity to dyad...
  ==> SSH to dyad: OK
  [2/12] Pre-flight: checking model cache on dyad...
  ==> Model cache found on dyad: OK
  [3/12] Stopping cluster services on monad...
  [4/12] Stopping cluster services on dyad...
  [5/12] Removing stale containers on both nodes...
  [6/12] Installing spark-vllm-standalone.service on monad...
  [7/12] Installing node.env on monad...
  ==> Installed ~/.config/spark-tools/node.env.monad → node.env
  [8/12] Installing spark-vllm-standalone.service on dyad...
  [11/12] Syncing model.env + node.env to dyad...
  ==> Synced node.env.dyad → dyad:~/.config/spark-tools/node.env
  [12/12] Enabling and starting services on both nodes...

  Split mode active.
    monad → vLLM standalone on port 8000 (TP=1)
    dyad  → vLLM standalone on port 8000 (TP=1)

  Run 'spark-mode status' to verify service states.

Activate cluster topology (live — installs services, requires sudo):
  $ sudo spark-mode cluster
  Switching to CLUSTER mode (Ray TP=2 across monad + dyad)...

  [1/9] Stopping standalone services on monad...
  [2/9] Stopping standalone services on dyad...
  [3/9] Removing stale containers on both nodes...
  [4/9] Removing per-node overrides (node.env)...
  [5/9] Installing Ray services on monad...
  [6/9] Installing spark-ray-worker.service on dyad...
  [7/9] Starting Ray cluster...
  ==> Waiting 5s for Ray head to initialise...
  ==> Waiting 10s for Ray worker to join...
  [8/9] Starting vLLM (Ray distributed backend)...
  [9/9] Restarting proxy and saving topology...

  Cluster mode active.
    Ray head  → monad  (192.168.1.10)
    Ray worker→ dyad   (dyad)
    vLLM      → monad  (TP=2 distributed)

  Run 'spark-mode status' to verify service states.

Preview a mode switch (dry-run):
  $ spark-mode --dry-run swarm --engine trtllm
  [dry-run] Would switch: ray+vllm → swarm+trtllm

  [dry-run] Would update: /home/user/.config/spark-tools/cluster.env
    SPARK_MODE=swarm
    SPARK_ENGINE=trtllm

    Note: TRT-LLM uses port 8355 by default

    If services are running, you would need: spark-stop && spark-serve

Preview a topology change (dry-run):
  $ sudo spark-mode split --dry-run
  [dry-run] Would switch to SPLIT mode (two independent vLLM instances, TP=1 per node)

    [1/12]  Pre-flight: verify SSH to dyad
    [2/12]  Pre-flight: check model cache on dyad
    ...
    [12/12] Enable + start services on both nodes; save topology

    Result: monad → vLLM standalone TP=1, dyad → vLLM standalone TP=1

Check live service states:
  $ spark-mode status
  Spark Topology
    Current topology: split

  === monad (primary) ===
    spark-vllm-standalone: active

  === dyad (secondary) ===
    spark-vllm-standalone: active

  spark-proxy: active

EXIT CODES
==========
  0   Success
  1   Error — SSH unreachable, model cache missing on dyad, config not found,
      MODEL_NAME not set, sudo not used for split/cluster, unknown argument

SEE ALSO
========
  spark-help          Full list of spark commands with descriptions
  spark-init          Initialize configuration (must run before spark-mode)
  spark-set-model     Change the active model (split mode: restarts services)
  spark-serve         Start inference services (after orchestration mode change)
  spark-stop          Stop inference services
  spark-status        Check cluster and API endpoint health
EOF
    echo ""
    echo "For short help: $(basename "$0") -h"
    exit 0
fi

#=============================================================================
# TOPOLOGY COMMANDS — split / cluster / status
# These are dispatched early; they load config then hand off to helpers below.
#=============================================================================
case "${1:-}" in
    split|cluster|status)
        spark_load_config

        # When invoked via sudo, SUDO_USER is the real operator account.
        # All user-facing paths (config, cache, home) use that account.
        _SPARK_USER="${SUDO_USER:-$USER}"
        _SPARK_HOME="$(eval echo "~${_SPARK_USER}")"
        _SPARK_CFG="${_SPARK_HOME}/.config/spark-tools"
        _TOPOLOGY_FILE="${_SPARK_CFG}/topology"
        _TEMPLATE_DIR="${SPARK_TOOLS_DIR}/systemd"
        _DYAD="${SPARK_SECONDARY_HOST:-dyad}"

        # Parse --dry-run for topology commands
        _DRY_RUN=false
        for _arg in "$@"; do
            [[ "$_arg" == "--dry-run" ]] && _DRY_RUN=true
        done

        # ── Helpers ──────────────────────────────────────────────────────────

        _detect_head_ip() {
            ip route get 8.8.8.8 2>/dev/null | grep -oP 'src \K[\d.]+' \
                || ip addr show \
                   | grep -oP 'inet \K[\d.]+' \
                   | grep -v '^127\.' | grep -v '^172\.' | grep -v '^169\.254\.' \
                   | head -1
        }

        # Substitute all template placeholders.
        # Reads _HEAD_IP, _SPARK_USER, etc. from the calling scope.
        _process_template() {
            local template="$1"
            sed \
                -e "s|{{USERNAME}}|${_SPARK_USER}|g" \
                -e "s|{{HEAD_IP}}|${_HEAD_IP:-}|g" \
                -e "s|{{QSFP_IFACE}}|${SPARK_QSFP_IFACE:-enp1s0f0np0}|g" \
                -e "s|{{RAY_VLLM_IMAGE}}|${SPARK_RAY_VLLM_IMAGE:-scitrera/dgx-spark-vllm:0.15.1-t5}|g" \
                -e "s|{{PORT}}|${SPARK_PORT:-8000}|g" \
                -e "s|{{UPSTREAM_PORT}}|${SPARK_PORT:-8000}|g" \
                -e "s|{{PROXY_PORT}}|${SPARK_PROXY_PORT:-9000}|g" \
                -e "s|{{SPARK_TOOLS_DIR}}|${SPARK_TOOLS_DIR}|g" \
                -e "s|{{VLLM_BACKENDS}}|${_VLLM_BACKENDS:-http://localhost:${SPARK_PORT:-8000}}|g" \
                "$template"
        }

        # SSH wrappers targeting dyad.
        _ssh_dyad() {
            spark_ssh "${_DYAD}" "$@"
        }
        # With TTY — use for remote sudo commands (not piped input).
        _ssh_dyad_tty() {
            spark_ssh_tty "${_DYAD}" "$@"
        }

        _current_topology() {
            if [[ -f "${_TOPOLOGY_FILE}" ]]; then
                cat "${_TOPOLOGY_FILE}"
            else
                echo "cluster"
            fi
        }

        _save_topology() {
            mkdir -p "${_SPARK_CFG}"
            echo "$1" > "${_TOPOLOGY_FILE}"
            # Sync engine in cluster.env — both topologies use vllm.
            # NOTE: Do NOT write topology into SPARK_MODE. SPARK_MODE is the
            # orchestration backend (swarm|ray) used by spark_dispatch().
            # Topology (split|cluster) is stored only in the topology file.
            local _cluster_env="${_SPARK_CFG}/cluster.env"
            if [[ -f "${_cluster_env}" ]]; then
                if [[ "$1" == "split" ]]; then
                    sed -i "s/^SPARK_ENGINE=.*/SPARK_ENGINE=vllm/" "${_cluster_env}"
                elif [[ "$1" == "cluster" ]]; then
                    sed -i "s/^SPARK_ENGINE=.*/SPARK_ENGINE=vllm/" "${_cluster_env}"
                fi
            fi
        }

        # ── status ────────────────────────────────────────────────────────────
        _do_status() {
            local topo
            topo="$(_current_topology)"
            _bold "Spark Topology"
            echo "  Current topology: ${topo}"
            echo ""

            if [[ "$topo" == "split" ]]; then
                echo "=== monad (primary) ==="
                if systemctl is-active --quiet spark-vllm-standalone 2>/dev/null; then
                    _green "  spark-vllm-standalone: active"
                else
                    _yellow "  spark-vllm-standalone: inactive"
                fi

                echo ""
                echo "=== dyad (secondary) ==="
                if _ssh_dyad "systemctl is-active --quiet spark-vllm-standalone" 2>/dev/null; then
                    _green "  spark-vllm-standalone: active"
                else
                    _yellow "  spark-vllm-standalone: inactive or unreachable"
                fi
            else
                echo "=== monad (primary) ==="
                if systemctl is-active --quiet spark-ray-head 2>/dev/null; then
                    _green "  spark-ray-head: active"
                else
                    _yellow "  spark-ray-head: inactive"
                fi
                if systemctl is-active --quiet spark-ray-vllm 2>/dev/null; then
                    _green "  spark-ray-vllm: active"
                else
                    _yellow "  spark-ray-vllm: inactive"
                fi

                echo ""
                echo "=== dyad (secondary) ==="
                if _ssh_dyad "systemctl is-active --quiet spark-ray-worker" 2>/dev/null; then
                    _green "  spark-ray-worker: active"
                else
                    _yellow "  spark-ray-worker: inactive or unreachable"
                fi
            fi

            echo ""
            if systemctl is-active --quiet spark-proxy 2>/dev/null; then
                _green "spark-proxy: active"
            else
                _yellow "spark-proxy: inactive"
            fi
        }

        # ── split ─────────────────────────────────────────────────────────────
        _do_split() {
            if [[ $EUID -ne 0 ]]; then
                spark_die "spark-mode split requires sudo (systemd service installation needs root)."
            fi

            if [[ -z "${MODEL_NAME:-}" ]]; then
                spark_die "MODEL_NAME is not set. Check ${_SPARK_CFG}/model.env"
            fi

            # ── Resolve per-node models ──────────────────────────────────────
            # In split mode each node can serve a different model.  model.env
            # provides the monad model; node.env.dyad may override MODEL_NAME
            # for dyad.  Detect this so pre-flight checks the right cache on
            # each node and the summary shows accurate per-node info.
            local _monad_model="${MODEL_NAME}"
            local _dyad_model="${MODEL_NAME}"
            local _dyad_node_env_file="${_SPARK_CFG}/node.env.${_DYAD:-dyad}"
            if [[ -f "${_dyad_node_env_file}" ]]; then
                local _override
                _override="$(grep -m1 '^MODEL_NAME=' "${_dyad_node_env_file}" 2>/dev/null | cut -d= -f2)"
                if [[ -n "${_override}" ]]; then
                    _dyad_model="${_override}"
                fi
            fi

            local _multi_model=false
            if [[ "${_monad_model}" != "${_dyad_model}" ]]; then
                _multi_model=true
            fi

            # Derive HuggingFace hub cache dirs for each node's model.
            # "Org/ModelName" → "models--Org--ModelName"
            local _monad_cache _dyad_cache
            _monad_cache="${_SPARK_HOME}/.cache/huggingface/hub/models--$(echo "${_monad_model}" | sed 's|/|--|g')"
            _dyad_cache="${_SPARK_HOME}/.cache/huggingface/hub/models--$(echo "${_dyad_model}" | sed 's|/|--|g')"

            _HEAD_IP="$(_detect_head_ip)"

            echo "Switching to SPLIT mode (two independent vLLM instances, TP=1 per node)..."
            if [[ "${_multi_model}" == true ]]; then
                echo "  Multi-model: monad → ${_monad_model}"
                echo "               dyad  → ${_dyad_model}"
            fi
            echo ""

            # ── [1/12] Pre-flight: SSH connectivity ──────────────────────────
            echo "[1/12] Pre-flight: verifying SSH connectivity to dyad..."
            if ! _ssh_dyad "true" 2>/dev/null; then
                spark_die "Cannot reach dyad via SSH. Check SSH keys and network connectivity."
            fi
            spark_info "SSH to dyad: OK"

            # ── [2/12] Pre-flight: model cache on both nodes ─────────────────
            echo "[2/12] Pre-flight: checking model caches..."
            local _preflight_ok=true

            # Check monad's model cache (local)
            if [[ ! -d "${_monad_cache}" ]]; then
                echo ""
                spark_error "Model cache not found on monad at:"
                echo "  ${_monad_cache}"
                echo ""
                echo "Download the model on monad first:"
                echo "  huggingface-cli download '${_monad_model}'"
                echo ""
                _preflight_ok=false
            else
                spark_info "monad: ${_monad_model} cache OK"
            fi

            # Check dyad's model cache (remote — use dyad's model, not monad's)
            if ! _ssh_dyad "test -d '${_dyad_cache}'" 2>/dev/null; then
                echo ""
                spark_error "Model cache not found on dyad at:"
                echo "  ${_dyad_cache}"
                echo ""
                echo "Download the model on dyad first:"
                echo "  ssh ${_DYAD} huggingface-cli download '${_dyad_model}'"
                echo ""
                _preflight_ok=false
            else
                spark_info "dyad:  ${_dyad_model} cache OK"
            fi

            if [[ "${_preflight_ok}" != true ]]; then
                exit 1
            fi

            # ── [3/12] Stop cluster services on monad ────────────────────────
            echo "[3/12] Stopping cluster services on monad..."
            systemctl stop  spark-ray-vllm   2>/dev/null || true
            systemctl stop  spark-ray-head   2>/dev/null || true
            systemctl disable spark-ray-vllm 2>/dev/null || true
            systemctl disable spark-ray-head 2>/dev/null || true
            # Swarm stack (if running)
            systemctl stop  spark-swarm-stack   2>/dev/null || true
            systemctl disable spark-swarm-stack 2>/dev/null || true

            # ── [4/12] Stop cluster services on dyad ─────────────────────────
            echo "[4/12] Stopping cluster services on dyad..."
            _ssh_dyad_tty "sudo systemctl stop spark-ray-worker    2>/dev/null || true; \
                          sudo systemctl disable spark-ray-worker 2>/dev/null || true"

            # ── [5/12] Remove stale containers on both nodes ─────────────────
            echo "[5/12] Removing stale containers on both nodes..."
            docker rm -f spark-ray spark-vllm 2>/dev/null || true
            _ssh_dyad "docker rm -f spark-ray spark-vllm 2>/dev/null || true"

            # Now that services and containers are stopped, resolve the port.
            # Doing this AFTER cleanup avoids needlessly bumping the port when
            # our own previous vLLM instance was the process holding it.
            spark_resolve_port

            # ── [6/12] Install standalone service on monad ───────────────────
            echo "[6/12] Installing spark-vllm-standalone.service on monad..."
            _process_template "${_TEMPLATE_DIR}/spark-vllm-standalone.service.template" \
                > /etc/systemd/system/spark-vllm-standalone.service

            # ── [7/12] Install node.env on monad ─────────────────────────────
            echo "[7/12] Installing node.env on monad..."
            local monad_node_env="${_SPARK_CFG}/node.env.${SPARK_PRIMARY_HOST:-monad}"
            if [[ ! -f "${monad_node_env}" ]]; then
                # Auto-install from example if available
                local _example="${SPARK_TOOLS_DIR}/config/node.env.${SPARK_PRIMARY_HOST:-monad}.example"
                if [[ -f "${_example}" ]]; then
                    sudo -u "${_SPARK_USER}" cp "${_example}" "${monad_node_env}"
                    spark_info "Installed example → ${monad_node_env}"
                else
                    printf 'TP_SIZE=1\n' | sudo -u "${_SPARK_USER}" tee "${monad_node_env}" > /dev/null
                    spark_info "Created minimal ${monad_node_env} (TP_SIZE=1)"
                fi
            fi
            cp "${monad_node_env}" "${_SPARK_CFG}/node.env"
            spark_info "Activated ${monad_node_env} → node.env"

            # ── [8/12] Install standalone service on dyad ────────────────────
            echo "[8/12] Installing spark-vllm-standalone.service on dyad..."
            _process_template "${_TEMPLATE_DIR}/spark-vllm-standalone.service.template" \
                | _ssh_dyad "cat > /tmp/.spark-service-tmp"
            _ssh_dyad_tty "sudo mv /tmp/.spark-service-tmp /etc/systemd/system/spark-vllm-standalone.service"

            # ── [11/12] Sync config files to dyad ─────────────────────────────

            # -- [9/12] Install proxy service ----------------------------------
            echo "[9/12] Installing spark-proxy.service on monad..."
            _VLLM_BACKENDS="http://localhost:${SPARK_PORT:-8000},http://${_DYAD}:${SPARK_PORT:-8000}"
            _process_template "${_TEMPLATE_DIR}/spark-proxy.service.template" \
                > /etc/systemd/system/spark-proxy.service

            # -- [10/12] Ensure proxy secret exists ----------------------------
            echo "[10/12] Checking proxy secret..."
            local _secret_dir="${_SPARK_HOME}/.config/vllm-proxy"
            local _secret_file="${_secret_dir}/secret.env"
            if [[ ! -f "${_secret_file}" ]]; then
                spark_info "Generating proxy secret..."
                sudo -u "${_SPARK_USER}" mkdir -p "${_secret_dir}"
                sudo -u "${_SPARK_USER}" chmod 700 "${_secret_dir}"
                local _new_secret
                _new_secret="$(openssl rand -hex 32)"
                echo "VLLM_PROXY_SECRET=${_new_secret}" \
                    | sudo -u "${_SPARK_USER}" tee "${_secret_file}" > /dev/null
                sudo -u "${_SPARK_USER}" chmod 600 "${_secret_file}"
                spark_info "Secret written to ${_secret_file}"
            else
                spark_info "Proxy secret already exists: ${_secret_file}"
            fi

            echo "[11/12] Syncing model.env + node.env to dyad..."
            _ssh_dyad "mkdir -p '${_SPARK_CFG}'"
            # Sync model.env so dyad knows what model to serve
            cat "${_SPARK_CFG}/model.env" \
                | _ssh_dyad "cat > '${_SPARK_CFG}/model.env'"
            # Sync dyad-specific node.env (auto-install from example if missing)
            local dyad_node_env="${_SPARK_CFG}/node.env.${_DYAD}"
            if [[ ! -f "${dyad_node_env}" ]]; then
                local _dyad_example="${SPARK_TOOLS_DIR}/config/node.env.${_DYAD}.example"
                if [[ -f "${_dyad_example}" ]]; then
                    sudo -u "${_SPARK_USER}" cp "${_dyad_example}" "${dyad_node_env}"
                    spark_info "Installed example → ${dyad_node_env}"
                else
                    printf 'TP_SIZE=1\n' | sudo -u "${_SPARK_USER}" tee "${dyad_node_env}" > /dev/null
                    spark_info "Created minimal ${dyad_node_env} (TP_SIZE=1)"
                fi
            fi
            cat "${dyad_node_env}" \
                | _ssh_dyad "cat > '${_SPARK_CFG}/node.env'"
            spark_info "Synced ${dyad_node_env} → dyad:node.env"

            # ── [12/12] Enable + start services; save topology ────────────────
            echo "[12/12] Enabling and starting services on both nodes..."
            systemctl daemon-reload
            _ssh_dyad_tty "sudo systemctl daemon-reload"

            systemctl enable spark-vllm-standalone
            systemctl start  spark-vllm-standalone
            _ssh_dyad_tty "sudo systemctl enable spark-vllm-standalone; \
                           sudo systemctl start  spark-vllm-standalone"

            # Enable and start the proxy (installed in step 9/12)
            systemctl enable spark-proxy
            systemctl start  spark-proxy

            _save_topology "split"

            echo ""
            _green "Split mode active."
            echo "  monad → vLLM standalone on port ${SPARK_PORT:-8000} (TP=1)"
            echo "  dyad  → vLLM standalone on port ${SPARK_PORT:-8000} (TP=1)"
            echo "  proxy → load balancer on port ${SPARK_PROXY_PORT:-9000}"
            echo ""

            # Show connection details
            local _proxy_port="${SPARK_PROXY_PORT:-9000}"
            local _direct_port="${SPARK_PORT:-8000}"
            local _model="${SERVED_MODEL_NAME:-${MODEL_NAME}}"
            local _token=""
            local _secret_file="${_SPARK_HOME}/.config/vllm-proxy/secret.env"
            if [[ -f "${_secret_file}" ]]; then
                _token="$(grep '^VLLM_PROXY_SECRET=' "${_secret_file}" | cut -d= -f2 | tr -d '"'"'")"
            fi

            _bold "Connect to this cluster:"
            echo ""
            echo "  API (load balanced):  http://${SPARK_PRIMARY_HOST}:${_proxy_port}/v1"
            echo "  API (direct monad):   http://${SPARK_PRIMARY_HOST}:${_direct_port}/v1"
            echo "  API (direct dyad):    http://${_DYAD}:${_direct_port}/v1"
            if [[ "${_multi_model}" == true ]]; then
                echo "  Model (monad):        ${_monad_model}"
                echo "  Model (dyad):         ${_dyad_model}"
            else
                echo "  Model:                ${_model}"
            fi
            if [[ -n "${_token}" ]]; then
                echo "  API key (proxy):      ${_token}"
            fi
            echo ""
            echo "  Amplifier:"
            echo "    amplifier provider add vllm \\"
            echo "      --base-url http://${SPARK_PRIMARY_HOST}:${_proxy_port}/v1 \\"
            if [[ -n "${_token}" ]]; then
                echo "      --api-key ${_token} \\"
            fi
            if [[ "${_multi_model}" == true ]]; then
                echo "      --model ${_monad_model}   # or ${_dyad_model}"
            else
                echo "      --model ${_model}"
            fi
            echo ""
            echo "Run 'spark-mode status' to verify service states."
        }

        # ── cluster ───────────────────────────────────────────────────────────
        _do_cluster() {
            if [[ $EUID -ne 0 ]]; then
                spark_die "spark-mode cluster requires sudo (systemd service installation needs root)."
            fi

            _HEAD_IP="$(_detect_head_ip)"

            echo "Switching to CLUSTER mode (Ray TP=2 across monad + dyad)..."
            echo ""

            # ── [1/9] Stop standalone on monad ───────────────────────────────
            echo "[1/9] Stopping standalone services on monad..."
            systemctl stop    spark-vllm-standalone 2>/dev/null || true
            systemctl disable spark-vllm-standalone 2>/dev/null || true

            # ── [2/9] Stop standalone on dyad ────────────────────────────────
            echo "[2/9] Stopping standalone services on dyad..."
            _ssh_dyad_tty "sudo systemctl stop    spark-vllm-standalone 2>/dev/null || true; \
                          sudo systemctl disable spark-vllm-standalone 2>/dev/null || true"

            # ── [3/9] Remove stale containers on both nodes ──────────────────
            echo "[3/9] Removing stale containers on both nodes..."
            docker rm -f spark-ray spark-vllm 2>/dev/null || true
            _ssh_dyad "docker rm -f spark-ray spark-vllm 2>/dev/null || true"

            # ── [4/9] Remove per-node overrides ──────────────────────────────
            echo "[4/9] Removing per-node overrides (node.env)..."
            rm -f "${_SPARK_CFG}/node.env"
            _ssh_dyad "rm -f '${_SPARK_CFG}/node.env'" 2>/dev/null || true

            # ── [5/9] Install Ray services on monad ──────────────────────────
            echo "[5/9] Installing Ray services on monad..."
            _process_template "${_TEMPLATE_DIR}/spark-ray-head.service.template" \
                > /etc/systemd/system/spark-ray-head.service
            _process_template "${_TEMPLATE_DIR}/spark-ray-vllm.service.template" \
                > /etc/systemd/system/spark-ray-vllm.service

            # ── [6/9] Install Ray worker service on dyad ─────────────────────
            echo "[6/9] Installing spark-ray-worker.service on dyad..."
            _process_template "${_TEMPLATE_DIR}/spark-ray-worker.service.template" \
                | _ssh_dyad "cat > /tmp/.spark-service-tmp"
            _ssh_dyad_tty "sudo mv /tmp/.spark-service-tmp /etc/systemd/system/spark-ray-worker.service"

            # ── [7/9] Start Ray cluster ───────────────────────────────────────
            echo "[7/9] Starting Ray cluster..."
            systemctl daemon-reload
            _ssh_dyad_tty "sudo systemctl daemon-reload"

            systemctl enable spark-ray-head
            systemctl start  spark-ray-head
            spark_info "Waiting 5s for Ray head to initialise..."
            sleep 5

            _ssh_dyad_tty "sudo systemctl enable spark-ray-worker; \
                           sudo systemctl start  spark-ray-worker"
            spark_info "Waiting 10s for Ray worker to join..."
            sleep 10

            # ── [8/9] Start vLLM on monad ────────────────────────────────────
            echo "[8/9] Starting vLLM (Ray distributed backend)..."
            systemctl enable spark-ray-vllm
            systemctl start  spark-ray-vllm

            # ── [9/9] Restart proxy + save topology ──────────────────────────
            echo "[9/9] Restarting proxy and saving topology..."
            systemctl restart spark-proxy 2>/dev/null || true
            _save_topology "cluster"

            echo ""
            _green "Cluster mode active."
            echo "  Ray head  → monad  (${_HEAD_IP})"
            echo "  Ray worker→ dyad   (${_DYAD})"
            echo "  vLLM      → monad  (TP=2 distributed)"
            echo ""
            echo "Run 'spark-mode status' to verify service states."
        }

        # ── Dispatch topology command ─────────────────────────────────────────
        case "$1" in
            split)
                if [[ "$_DRY_RUN" == true ]]; then
                    if [[ $EUID -ne 0 ]]; then
                        echo "[dry-run] Note: split requires sudo (not checked in dry-run)"
                    fi
                    echo "[dry-run] Would switch to SPLIT mode (two independent vLLM instances, TP=1 per node)"
                    echo ""
                    echo "  [1/12]  Pre-flight: verify SSH to ${SPARK_SECONDARY_HOST}"
                    echo "  [2/12]  Pre-flight: check model cache on ${SPARK_SECONDARY_HOST}"
                    echo "  [3/12]  Stop cluster services on ${SPARK_PRIMARY_HOST}"
                    echo "  [4/12]  Stop cluster services on ${SPARK_SECONDARY_HOST}"
                    echo "  [5/12]  Remove stale containers on both nodes"
                    echo "  [6/12]  Install spark-vllm-standalone.service on ${SPARK_PRIMARY_HOST}"
                    echo "  [7/12]  Install node.env on ${SPARK_PRIMARY_HOST}"
                    echo "  [8/12]  Install spark-vllm-standalone.service on ${SPARK_SECONDARY_HOST}"
                    echo "  [9/12]  Install spark-proxy.service on ${SPARK_PRIMARY_HOST}"
                    echo "  [10/12] Check/create proxy secret"
                    echo "  [11/12] Sync model.env + node.env to ${SPARK_SECONDARY_HOST}"
                    echo "  [12/12] Enable + start services on both nodes; save topology"
                    echo ""
                    echo "  Result: monad → vLLM standalone TP=1, dyad → vLLM standalone TP=1"
                    exit 0
                fi
                _do_split
                ;;
            cluster)
                if [[ "$_DRY_RUN" == true ]]; then
                    if [[ $EUID -ne 0 ]]; then
                        echo "[dry-run] Note: cluster requires sudo (not checked in dry-run)"
                    fi
                    echo "[dry-run] Would switch to CLUSTER mode (Ray TP=2 across monad + dyad)"
                    echo ""
                    echo "  [1/9] Stop standalone services on ${SPARK_PRIMARY_HOST}"
                    echo "  [2/9] Stop standalone services on ${SPARK_SECONDARY_HOST}"
                    echo "  [3/9] Remove stale containers on both nodes"
                    echo "  [4/9] Remove per-node overrides (node.env)"
                    echo "  [5/9] Install Ray services on ${SPARK_PRIMARY_HOST}"
                    echo "  [6/9] Install spark-ray-worker.service on ${SPARK_SECONDARY_HOST}"
                    echo "  [7/9] Start Ray cluster (head + worker)"
                    echo "  [8/9] Start vLLM (Ray distributed backend)"
                    echo "  [9/9] Restart proxy and save topology"
                    echo ""
                    echo "  Result: Ray head → monad, Ray worker → dyad, vLLM TP=2 distributed"
                    exit 0
                fi
                _do_cluster
                ;;
            status)  _do_status  ;;
        esac
        ;;
esac

#=============================================================================
# ORCHESTRATION COMMANDS — swarm / ray (update cluster.env only)
#=============================================================================

spark_load_config

# No arguments: show current configuration
if [[ $# -eq 0 ]]; then
    spark_show_config
    exit 0
fi

# Parse arguments
NEW_MODE=""
NEW_ENGINE=""
_DRY_RUN=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        swarm|ray) NEW_MODE="$1" ;;
        --engine)
            shift
            NEW_ENGINE="${1:-}"
            [[ -z "$NEW_ENGINE" ]] && spark_die "--engine requires a value (trtllm or vllm)"
            ;;
        --dry-run) _DRY_RUN=true ;;
        *)
            spark_die "Unknown argument: $1. Use --help for usage."
            ;;
    esac
    shift
done

# Apply defaults (keep current values if not specified)
NEW_MODE="${NEW_MODE:-$SPARK_MODE}"
NEW_ENGINE="${NEW_ENGINE:-$SPARK_ENGINE}"

# Auto-correct: ray + trtllm is not a valid combination
if [[ "$NEW_MODE" == "ray" && "$NEW_ENGINE" == "trtllm" ]]; then
    spark_warn "Ray mode does not support trtllm. Switching engine to vllm."
    NEW_ENGINE="vllm"
fi

# Nothing changed
if [[ "$NEW_MODE" == "$SPARK_MODE" && "$NEW_ENGINE" == "$SPARK_ENGINE" ]]; then
    echo "Already in ${NEW_MODE} + ${NEW_ENGINE} mode. No change."
    exit 0
fi

if [[ "$_DRY_RUN" == true ]]; then
    echo "[dry-run] Would switch: ${SPARK_MODE}+${SPARK_ENGINE} → ${NEW_MODE}+${NEW_ENGINE}"
    echo ""
    echo "[dry-run] Would update: $SPARK_CLUSTER_ENV"
    echo "  SPARK_MODE=${NEW_MODE}"
    echo "  SPARK_ENGINE=${NEW_ENGINE}"
    echo ""
    if [[ "$NEW_ENGINE" != "$SPARK_ENGINE" ]]; then
        if [[ "$NEW_ENGINE" == "trtllm" ]]; then
            echo "  Note: TRT-LLM uses port ${TRTLLM_PORT:-8355} by default"
        else
            echo "  Note: vLLM uses port ${SPARK_PORT:-8000} by default"
        fi
        echo ""
    fi
    echo "  If services are running, you would need: spark-stop && spark-serve"
    exit 0
fi

echo "Switching: ${SPARK_MODE}+${SPARK_ENGINE} → ${NEW_MODE}+${NEW_ENGINE}"
echo ""

# Update cluster.env
sed -i \
    -e "s/^SPARK_MODE=.*/SPARK_MODE=${NEW_MODE}/" \
    -e "s/^SPARK_ENGINE=.*/SPARK_ENGINE=${NEW_ENGINE}/" \
    "$SPARK_CLUSTER_ENV"

echo "Updated: $SPARK_CLUSTER_ENV"
echo ""

# Engine-change port hints
if [[ "$NEW_ENGINE" != "$SPARK_ENGINE" ]]; then
    if [[ "$NEW_ENGINE" == "trtllm" ]]; then
        spark_info "Note: TRT-LLM uses port ${TRTLLM_PORT:-8355} by default"
    else
        spark_info "Note: vLLM uses port ${SPARK_PORT:-8000} by default"
    fi
fi

echo ""
echo "Current orchestration mode: ${NEW_MODE} + ${NEW_ENGINE}"
echo ""
echo "If services are running, stop and restart them:"
echo "  spark-stop && spark-serve"
