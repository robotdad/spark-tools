#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
source "${SCRIPT_DIR}/../lib/spark-common.sh"

if [[ "${1:-}" == "-h" ]]; then
    cat <<'SHORT'
Usage: spark-stop [--kill-only | --stack | --swarm]
Stop all running inference services on the Spark cluster.

  (no flag)    Kill inference processes; keep Docker stack + Swarm intact (default)
  --kill-only  Same as no flag — fastest, this is what spark-reset uses
  --stack      Kill processes AND remove the Docker stack 'spark'
  --swarm      Full teardown — kill processes, remove stack, leave Swarm entirely

In ray mode no flags are accepted; all Ray and vLLM services are stopped uniformly.
Safe to call on an idle or partially-failed cluster.

Run 'spark-stop --help' for full details.
SHORT
    exit 0
fi

if [[ "${1:-}" == "--help" ]]; then
    cat <<'EOF'
spark-stop — Stop all running inference services on the Spark cluster

Tears down the inference stack according to the current SPARK_MODE. Use this
when reconfiguring the model, switching modes, freeing GPU memory, or shutting
down for maintenance. spark-reset calls spark-stop automatically before
restarting, so you rarely need to run this directly unless you want to stop
without immediately restarting.

In swarm mode three levels of teardown are available via flags, ranging from
fast (kill processes only) to complete (leave the Swarm). In ray mode no
flags are accepted; all Ray and vLLM services are stopped uniformly.

Usage:
  spark-stop [--kill-only | --stack | --swarm]

Preconditions:
  - ~/.config/spark-tools/cluster.env exists  (run spark-init to create it)
  - Services need not be running; spark-stop is safe to call on an idle or
    partially-failed cluster
  - ray + trtllm is not a valid combination and is rejected before any stop
    action is taken

Options (swarm mode only; ignored or unavailable in ray mode):
  (none)        Same as --kill-only; this is the default.

  --kill-only   Kill inference server processes only. The Docker stack 'spark'
                and Swarm membership remain intact. Fastest option — use when
                you just want to restart the model. This is the path taken by
                spark-reset.

  --stack       Kill inference processes AND remove the Docker stack ('spark')
                from the Swarm. Swarm membership is preserved. Use before
                redeploying with a changed stack configuration. The next
                spark-serve will redeploy the stack from scratch, which is
                slower than --kill-only.

  --swarm       Kill inference processes, remove the Docker stack, AND issue
                'docker swarm leave --force' on all nodes. Full teardown.
                Swarm must be re-initialized (via spark-init or manually)
                before spark-serve will work again. Use when changing Swarm
                topology, node membership, or the QSFP network configuration.

  In ray mode: stops vllm-ray-head and vllm (on monad), then SSHs to dyad to
  stop vllm-ray-worker. SSH uses ConnectTimeout=5s; a timeout is reported as
  a failure but does not prevent local services from being stopped.

Behavior:
  1. Loads config (cluster.env → model.env → node.env overrides)
  2. Validates SPARK_MODE and SPARK_ENGINE; exits 1 on invalid combination
  3. Execs backends/${SPARK_MODE}/stop.sh with the provided flags — spark-stop
     does not return; all output and exit code come from the backend

  On success: services are stopped; GPU memory is freed. In-flight requests
              are interrupted without connection draining.
  On failure: backend exits non-zero; partial stop is possible. Running
              spark-stop again is safe. spark-reset ignores stop failures,
              so it is the preferred recovery path when stop itself is broken.

Examples:
  # Default: kill inference processes, keep Docker stack and Swarm intact
  spark-stop

  # Remove the Docker stack too (useful before changing stack config)
  spark-stop --stack

  # Full teardown — leave the Swarm entirely
  spark-stop --swarm

  # Confirm all services are down after stopping
  spark-check

Exit codes:
  0   Stop completed successfully
  1   Configuration error (missing cluster.env, invalid mode/engine
      combination) or backend script missing/not executable; partial stop
      output may appear before the error

See also:
  spark-serve      Restart inference after stopping
  spark-reset      Stop + restart in one command (tolerates stop failures)
  spark-check      Verify services are actually down after stopping
  spark-status     Backend service and container status
  spark-help       Comprehensive quick reference for all spark-tools commands
EOF

    echo ""
    echo "For short help: $(basename "$0") -h"
    exit 0
fi

spark_load_config

# Split topology manages standalone systemd units directly — no backend dispatch.
if [[ "$(spark_read_topology)" == "split" ]]; then
    spark_info "Stopping split-mode services..."
    sudo systemctl stop spark-vllm-standalone 2>/dev/null || true
    sudo systemctl stop spark-proxy 2>/dev/null || true
    spark_ssh "${SPARK_SECONDARY_HOST:-dyad}" \
        "sudo systemctl stop spark-vllm-standalone" 2>/dev/null || true
    spark_info "Split-mode services stopped."
    exit 0
fi

spark_dispatch stop "$@"
