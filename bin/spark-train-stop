#!/usr/bin/env bash
# spark-train-stop - Graceful training shutdown with checkpoint save
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
source "${SCRIPT_DIR}/../lib/spark-common.sh"

if [[ "${1:-}" == "-h" ]]; then
    cat <<'SHORT'
Usage: spark-train-stop [--immediate]
Stop training gracefully, allowing checkpoint save.

  spark-train-stop              Send SIGTERM, wait for checkpoint (up to CHECKPOINT_TIMEOUT)
  spark-train-stop --immediate  Send SIGKILL immediately, no waiting

Stops training processes on both nodes (monad local, dyad via SSH).

Use 'spark-train-stop --help' for the extended reference (designed for AI agents like Amplifier).
SHORT
    exit 0
fi

if [[ "${1:-}" == "--help" ]]; then
    cat <<'EOF'
spark-train-stop — Graceful training shutdown with checkpoint save

Sends SIGTERM to training processes on both nodes, then waits up to
CHECKPOINT_TIMEOUT seconds (default: 120, from training.env) for the
training script to save a checkpoint and exit cleanly.

If the timeout expires, reports the situation and suggests using
--immediate for a forced SIGKILL.

Usage:
  spark-train-stop [--immediate]

Options:
  --immediate   Send SIGKILL instead of SIGTERM. No waiting for checkpoint.
                Use when the training process is hung or unresponsive.

Behavior:
  1. Reads PID from /tmp/spark-train.pid (monad)
  2. Sends SIGTERM (or SIGKILL with --immediate) to local process
  3. SSHs to dyad and kills training processes there (pkill torchrun + pkill train.py)
  4. Waits up to CHECKPOINT_TIMEOUT seconds for clean exit
  5. Reports final step number and checkpoint location on success
  6. Removes PID file

Configuration:
  CHECKPOINT_TIMEOUT   Seconds to wait after SIGTERM (default: 120)
                       Set in ~/.config/spark-tools/training.env

Exit codes:
  0   Training stopped successfully
  1   No training was running, or stop failed

See also:
  spark-train          Launch training
  spark-train-status   Check training progress
  spark-train-resume   Resume from checkpoint
EOF

    echo ""
    echo "For short help: $(basename "$0") -h"
    exit 0
fi

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
IMMEDIATE=false
[[ "${1:-}" == "--immediate" ]] && IMMEDIATE=true

# ---------------------------------------------------------------------------
# Load config
# ---------------------------------------------------------------------------
spark_load_config

# Load training config (for CHECKPOINT_TIMEOUT), but don't die if missing
CHECKPOINT_TIMEOUT=120
if [[ -f "${SPARK_TRAINING_ENV}" ]]; then
    # shellcheck source=/dev/null
    source "${SPARK_TRAINING_ENV}"
    CHECKPOINT_TIMEOUT="${CHECKPOINT_TIMEOUT:-120}"
fi

SECONDARY="${SPARK_SECONDARY_HOST}"
LOG_FILE="${SPARK_TRAINING_LOG_DIR}/train.log"

# ---------------------------------------------------------------------------
# Check if training is running
# ---------------------------------------------------------------------------
if ! spark_training_running; then
    spark_warn "No training process detected (PID file missing or process dead)"
    spark_training_remove_pid  # Clean up any stale PID file
    echo "Nothing to stop."
    exit 1
fi

TRAIN_PID=$(spark_training_pid)
echo ""
_bold "=== Stopping Training ==="
echo ""
echo "  Local PID: ${TRAIN_PID}"
echo "  Timeout:   ${CHECKPOINT_TIMEOUT}s"
echo ""

# ---------------------------------------------------------------------------
# Kill remote training processes (dyad)
# ---------------------------------------------------------------------------
_bold "--- Stopping ${SECONDARY} ---"
spark_ssh "${SECONDARY}" "
    # Kill torchrun and training scripts
    pkill -f 'torchrun.*train.py' 2>/dev/null || true
    pkill -f 'train.py' 2>/dev/null || true
" 2>/dev/null && _green "  ✓ Sent stop signal to ${SECONDARY}" \
             || _yellow "  ~ Could not reach ${SECONDARY} (may already be stopped)"
echo ""

# ---------------------------------------------------------------------------
# Kill local training process (monad)
# ---------------------------------------------------------------------------
_bold "--- Stopping ${SPARK_PRIMARY_HOST} ---"

if [[ "$IMMEDIATE" == true ]]; then
    spark_info "Sending SIGKILL (--immediate)..."
    kill -9 "$TRAIN_PID" 2>/dev/null || true
    # Also kill any child processes
    pkill -9 -f "torchrun.*train.py" 2>/dev/null || true
    pkill -9 -f "train.py" 2>/dev/null || true
    _green "  ✓ Killed (SIGKILL)"
else
    spark_info "Sending SIGTERM (graceful)..."
    kill -15 "$TRAIN_PID" 2>/dev/null || true

    # Wait for process to exit
    spark_info "Waiting up to ${CHECKPOINT_TIMEOUT}s for checkpoint save..."
    elapsed=0
    while kill -0 "$TRAIN_PID" 2>/dev/null && [[ $elapsed -lt $CHECKPOINT_TIMEOUT ]]; do
        sleep 2
        elapsed=$(( elapsed + 2 ))
        # Show progress every 10 seconds
        if (( elapsed % 10 == 0 )); then
            printf "  ... %ds / %ds\n" "$elapsed" "$CHECKPOINT_TIMEOUT"
        fi
    done

    if kill -0 "$TRAIN_PID" 2>/dev/null; then
        echo ""
        _yellow "  ~ Process still running after ${CHECKPOINT_TIMEOUT}s timeout"
        spark_warn "Training process did not exit within timeout."
        echo "  To force stop: spark-train-stop --immediate"
        echo ""
        exit 1
    else
        _green "  ✓ Process exited cleanly"
    fi
fi

# ---------------------------------------------------------------------------
# Clean up PID file
# ---------------------------------------------------------------------------
spark_training_remove_pid

# ---------------------------------------------------------------------------
# Report checkpoint info
# ---------------------------------------------------------------------------
echo ""
_bold "--- Result ---"

# Parse last step from log
LAST_STEP=$(grep -oP 'step[=: ]\K\d+' "$LOG_FILE" 2>/dev/null | tail -1 || echo "unknown")
echo "  Final step: ${LAST_STEP}"

# Check for checkpoint
if [[ -n "${TRAINING_CHECKPOINT_DIR:-}" && -d "${TRAINING_CHECKPOINT_DIR:-}" ]]; then
    LATEST_CKPT=$(ls -td "${TRAINING_CHECKPOINT_DIR}"/step_* "${TRAINING_CHECKPOINT_DIR}"/checkpoint_* 2>/dev/null | head -1 || echo "")
    if [[ -n "$LATEST_CKPT" ]]; then
        CKPT_SIZE=$(du -sh "$LATEST_CKPT" 2>/dev/null | awk '{print $1}' || echo "?")
        echo "  Checkpoint:  $(basename "$LATEST_CKPT") (${CKPT_SIZE})"
        echo "  Location:    ${LATEST_CKPT}"
    fi
fi
echo ""
_green "=== Training Stopped ==="
echo ""
echo "Resume with: spark-train-resume"
echo ""
