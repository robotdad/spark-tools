#!/usr/bin/env bash
# spark-train-stage - Stage tokenized training data to both nodes
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
source "${SCRIPT_DIR}/../lib/spark-common.sh"

if [[ "${1:-}" == "-h" ]]; then
    cat <<'SHORT'
Usage: spark-train-stage <source-path> [--verify]
Stage tokenized training data to both cluster nodes.

  spark-train-stage /mnt/corpus/shards/   Copy data to TRAINING_DATA_DIR on both nodes
  spark-train-stage --verify              Check existing staged data (no copy)

Uses rsync for efficient transfer. Verifies file counts match across nodes.

Use 'spark-train-stage --help' for the extended reference (designed for AI agents like Amplifier).
SHORT
    exit 0
fi

if [[ "${1:-}" == "--help" ]]; then
    cat <<'EOF'
spark-train-stage — Stage tokenized training data to both cluster nodes

Rsyncs tokenized data shards from a source directory to TRAINING_DATA_DIR
on both monad (local) and dyad (via SSH). After copying, verifies that
file counts match across nodes.

Usage:
  spark-train-stage <source-path>
  spark-train-stage --verify

Arguments:
  source-path    Path to the directory containing tokenized data shards.
                 Must be accessible from monad. Trailing slash is added
                 automatically if missing.

Options:
  --verify       Check existing staged data without copying anything.
                 Reports file count and size on each node, and whether
                 they match.

Behavior:
  1. Validates source-path exists and contains files
  2. Rsyncs source → TRAINING_DATA_DIR on monad (local copy/sync)
  3. Rsyncs source → TRAINING_DATA_DIR on dyad (via SSH)
  4. Counts files on both nodes and reports match/mismatch

Configuration:
  TRAINING_DATA_DIR   Destination directory on both nodes
                      Set in ~/.config/spark-tools/training.env

Exit codes:
  0   Data staged successfully and counts match (or --verify passed)
  1   Rsync failed, source not found, or file count mismatch

See also:
  spark-train        Launch training (requires staged data)
  spark-train-setup  Set up training environment first
EOF

    echo ""
    echo "For short help: $(basename "$0") -h"
    exit 0
fi

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
VERIFY_ONLY=false
SOURCE_PATH=""

for arg in "$@"; do
    case "$arg" in
        --verify) VERIFY_ONLY=true ;;
        -*)       spark_die "Unknown option: $arg. Use --help for usage." ;;
        *)
            [[ -n "$SOURCE_PATH" ]] && spark_die "Unexpected argument: $arg"
            SOURCE_PATH="$arg"
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Load config
# ---------------------------------------------------------------------------
spark_load_config
spark_load_training_config

SECONDARY="${SPARK_SECONDARY_HOST}"
DATA_DIR="${TRAINING_DATA_DIR}"

# ---------------------------------------------------------------------------
# Verify mode
# ---------------------------------------------------------------------------
if [[ "$VERIFY_ONLY" == true ]]; then
    echo ""
    _bold "=== Data Verification ==="
    echo "  Target: ${DATA_DIR}"
    echo ""

    # Local
    _bold "--- ${SPARK_PRIMARY_HOST} (local) ---"
    if [[ -d "$DATA_DIR" ]]; then
        local_count=$(find "$DATA_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')
        local_size=$(du -sh "$DATA_DIR" 2>/dev/null | awk '{print $1}' || echo "?")
        _green "  ✓ ${local_count} files, ${local_size}"
    else
        _red "  ✗ Directory not found"
    fi

    # Remote
    _bold "--- ${SECONDARY} (via SSH) ---"
    remote_info=$(spark_ssh "${SECONDARY}" "
        if [ -d '${DATA_DIR}' ]; then
            COUNT=\$(find '${DATA_DIR}' -type f 2>/dev/null | wc -l | tr -d ' ')
            SIZE=\$(du -sh '${DATA_DIR}' 2>/dev/null | awk '{print \$1}' || echo '?')
            echo \"\${COUNT}|\${SIZE}\"
        else
            echo '0|missing'
        fi
    " 2>/dev/null || echo "0|unreachable")

    IFS='|' read -r remote_count remote_size <<< "$remote_info"
    if [[ "$remote_count" -gt 0 ]]; then
        _green "  ✓ ${remote_count} files, ${remote_size}"
    else
        _red "  ✗ ${remote_size}"
    fi

    # Compare
    echo ""
    if [[ "${local_count:-0}" -gt 0 && "${local_count:-0}" == "${remote_count:-0}" ]]; then
        _green "=== File counts match: ${local_count} files on each node ==="
    elif [[ "${local_count:-0}" -gt 0 && "${remote_count:-0}" -gt 0 ]]; then
        _yellow "=== File count MISMATCH: ${SPARK_PRIMARY_HOST}=${local_count} ${SECONDARY}=${remote_count} ==="
    else
        _red "=== Data missing on one or both nodes ==="
    fi
    echo ""
    exit 0
fi

# ---------------------------------------------------------------------------
# Stage mode — requires source path
# ---------------------------------------------------------------------------
[[ -z "$SOURCE_PATH" ]] && spark_die "Source path required. Usage: spark-train-stage /path/to/shards"

# Ensure trailing slash for rsync
[[ "$SOURCE_PATH" != */ ]] && SOURCE_PATH="${SOURCE_PATH}/"

# Validate source
if [[ ! -d "$SOURCE_PATH" ]]; then
    spark_die "Source directory not found: ${SOURCE_PATH}"
fi

source_count=$(find "$SOURCE_PATH" -type f 2>/dev/null | wc -l | tr -d ' ')
source_size=$(du -sh "$SOURCE_PATH" 2>/dev/null | awk '{print $1}' || echo "?")

echo ""
_bold "=== Staging Training Data ==="
echo "  Source: ${SOURCE_PATH} (${source_count} files, ${source_size})"
echo "  Target: ${DATA_DIR}"
echo ""

# --- Local rsync ---
_bold "--- ${SPARK_PRIMARY_HOST} (local) ---"
spark_info "Syncing to local ${DATA_DIR}..."
mkdir -p "$DATA_DIR"
if rsync -a --info=progress2 "${SOURCE_PATH}" "${DATA_DIR}/"; then
    local_count=$(find "$DATA_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')
    _green "  ✓ ${local_count} files staged"
else
    _red "  ✗ rsync failed"
    exit 1
fi
echo ""

# --- Remote rsync ---
_bold "--- ${SECONDARY} (via SSH) ---"
spark_info "Syncing to ${SECONDARY}:${DATA_DIR}..."
spark_ssh "${SECONDARY}" "mkdir -p '${DATA_DIR}'" 2>/dev/null

# Use rsync over SSH
if rsync -a --info=progress2 -e "ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no" \
    "${SOURCE_PATH}" "${SECONDARY}:${DATA_DIR}/"; then
    remote_count=$(spark_ssh "${SECONDARY}" "find '${DATA_DIR}' -type f 2>/dev/null | wc -l | tr -d ' '" 2>/dev/null || echo "?")
    _green "  ✓ ${remote_count} files staged"
else
    _red "  ✗ rsync failed"
    exit 1
fi
echo ""

# --- Verify ---
if [[ "${local_count}" == "${remote_count}" ]]; then
    _green "=== Staging complete: ${local_count} files on each node ==="
else
    _yellow "=== Warning: file count mismatch: ${SPARK_PRIMARY_HOST}=${local_count} ${SECONDARY}=${remote_count} ==="
    echo "  Run: spark-train-stage --verify"
fi
echo ""
