# Per-node overrides for dyad (secondary node — aggressive profile)
# Copy to ~/.config/spark-tools/node.env.dyad  (or wherever spark-tools looks for it)
#
# In split-node mode each GB10 runs its own vLLM instance at TP_SIZE=1.
# These values are loaded AFTER model.env, so they win on any key they define.
# Override order: model.env → node.env.<hostname> (last-wins)
#
# Modeled after Brian's dgx-spark-cluster node.env.spark-2 (aggressive profile).
# Use higher utilization here if dyad has fewer resident workloads than monad.

# ── Parallelism ───────────────────────────────────────────────────────────────
# Single-node TP: each GB10 serves independently, no cross-node tensor parallelism.
# Flip back to 2 to run both GPUs on this node as a single large instance.
TP_SIZE=1

# ── Memory ────────────────────────────────────────────────────────────────────
# Aggressive utilization — safe when dyad is dedicated to inference with no other
# heavy processes. Back off to 0.85 if OOM errors appear under sustained load.
GPU_MEM_UTIL=0.90

# Maximum context length this node will serve (tokens).
# 262144 (256K) is achievable at 0.90 GPU_MEM_UTIL + FP8 KV cache on GB10.
# Drop to 131072 if you hit OOM during long-context requests.
MAX_MODEL_LEN=262144

# ── vLLM Extra Arguments ──────────────────────────────────────────────────────
# Single-node override of VLLM_EXTRA_ARGS from model.env:
#   - DROP   --enforce-eager   (only needed for multi-node TP=2; causes CUDA graph
#                               capture to skip, hurting throughput on TP=1)
#   - LOWER  --max-num-seqs    (longer context = more KV memory per seq; fewer
#                               concurrent sequences keeps us within VRAM budget)
#   All other flags inherited from model.env carry over via this full override.
VLLM_EXTRA_ARGS="--enable-prefix-caching --block-size 128 --attention-backend flashinfer --kv-cache-dtype fp8 --enable-auto-tool-choice --tool-call-parser qwen3_coder --max-num-seqs 32 --trust-remote-code"
