# Per-node overrides for monad (primary node — moderate profile)
# Copy to ~/.config/spark-tools/node.env.monad  (or wherever spark-tools looks for it)
#
# In split-node mode each GB10 runs its own vLLM instance at TP_SIZE=1.
# These values are loaded AFTER model.env, so they win on any key they define.
# Override order: model.env → node.env.<hostname> (last-wins)
#
# Modeled after Brian's dgx-spark-cluster node.env.spark-1 (moderate profile).

# ── Parallelism ───────────────────────────────────────────────────────────────
# Single-node TP: each GB10 serves independently, no cross-node tensor parallelism.
# Flip back to 2 to run both GPUs on this node as a single large instance.
TP_SIZE=1

# ── Memory ────────────────────────────────────────────────────────────────────
# Moderate utilization — leaves headroom for OS, Docker, and any side processes
# resident on the primary node. Raise toward 0.90 if monad is otherwise idle.
GPU_MEM_UTIL=0.80

# Maximum context length this node will serve (tokens).
# 131072 is a safe ceiling for 0.80 GPU_MEM_UTIL + FP8 KV cache on GB10.
# Raise to 262144 if memory profiling shows sufficient headroom.
MAX_MODEL_LEN=131072

# ── vLLM Extra Arguments ──────────────────────────────────────────────────────
# Single-node override of VLLM_EXTRA_ARGS from model.env:
#   - DROP   --enforce-eager   (only needed for multi-node TP=2; causes CUDA graph
#                               capture to skip, hurting throughput on TP=1)
#   - RAISE  --max-num-seqs    (more VRAM headroom per-seq at TP=1 vs TP=2)
#   All other flags inherited from model.env carry over via this full override.
VLLM_EXTRA_ARGS="--enable-prefix-caching --block-size 128 --attention-backend flashinfer --kv-cache-dtype fp8 --enable-auto-tool-choice --tool-call-parser qwen3_coder --max-num-seqs 64 --trust-remote-code"
