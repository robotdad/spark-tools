# Spark Tools - Model Configuration
# Copy to ~/.config/spark-tools/model.env
# Or use: spark-set-model <model-name>

# =============================================================================
# Model Identity
# =============================================================================
MODEL_NAME=nvidia/Qwen3-235B-A22B-FP4

# API alias returned by /v1/models (e.g. "qwen3-coder" instead of full HF path).
# Maps to --served-model-name in vLLM. Leave empty to use MODEL_NAME as-is.
# Useful so clients don't need to know the full HuggingFace repo path.
SERVED_MODEL_NAME=

# =============================================================================
# Parallelism & Memory
# =============================================================================
TP_SIZE=2
MAX_MODEL_LEN=32768
GPU_MEM_UTIL=0.85

# =============================================================================
# Container Image & Entrypoint
# =============================================================================
# VLLM_IMAGE: Docker image to use for the vLLM container.
#   Set automatically by spark-set-model from model profiles.
#   NGC images: nvcr.io/nvidia/vllm:YY.MM-py3
#   Docker Hub: vllm/vllm-openai:<tag>
#
# VLLM_SERVE_CMD: Controls the entrypoint command.
#   "vllm serve"  — NGC images (nvidia_entrypoint.sh, need explicit command)
#   ""            — Docker Hub images (vllm serve is the ENTRYPOINT already)
#   Set automatically by spark-set-model from model profiles.
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.03-py3
VLLM_SERVE_CMD="vllm serve"

# =============================================================================
# vLLM Extra Arguments
# =============================================================================
# Set automatically by spark-set-model from model profiles (profiles/ directory).
# Model-specific flags vary — see profiles/*.env and docs/MODEL-NOTES.md.
#
# Common flags:
# --enforce-eager:            ONLY needed for MULTI-NODE TP=2 (Triton crash on GB10)
# --enable-prefix-caching:   KV cache reuse for shared prefixes
# --block-size 128:           Safe on standard transformers, BREAKS on hybrid arch
# --attention-backend flashinfer: Optimized attention, but BREAKS on some models
# --kv-cache-dtype fp8:       ~40% KV memory savings
# --enable-auto-tool-choice:  Function-calling support
# --tool-call-parser <name>:  Model-specific parser (qwen3_coder, gemma4, hermes, etc.)
# --max-num-batched-tokens:   Minimum 4096 for hybrid architectures
# --trust-remote-code:        Required by some HF models
VLLM_EXTRA_ARGS="--enforce-eager --enable-prefix-caching --block-size 128 --attention-backend flashinfer --kv-cache-dtype fp8 --enable-auto-tool-choice --tool-call-parser qwen3_coder --max-num-seqs 16 --trust-remote-code"

# =============================================================================
# TRT-LLM Settings
# =============================================================================
# These apply when SPARK_ENGINE=trtllm
TRTLLM_PORT=8355
TRTLLM_MAX_BATCH_SIZE=4
TRTLLM_MAX_NUM_TOKENS=32768
TRTLLM_GPU_MEM_FRACTION=0.9
