# Spark Tools - Model Configuration
# Copy to ~/.config/spark-tools/model.env
# Or use: spark-set-model <model-name>

# =============================================================================
# Model Identity
# =============================================================================
MODEL_NAME=nvidia/Qwen3-235B-A22B-FP4

# API alias returned by /v1/models (e.g. "qwen3-coder" instead of full HF path).
# Maps to --served-model-name in vLLM. Leave empty to use MODEL_NAME as-is.
# Useful so clients don't need to know the full HuggingFace repo path.
SERVED_MODEL_NAME=

# =============================================================================
# Parallelism & Memory
# =============================================================================
TP_SIZE=2
MAX_MODEL_LEN=32768
GPU_MEM_UTIL=0.85

# =============================================================================
# vLLM Extra Arguments
# =============================================================================
# These apply when SPARK_ENGINE=vllm (both swarm and ray modes)
#
# --enforce-eager:            ONLY needed for MULTI-NODE TP=2 (avoids Triton allocator
#                             crash during CUDA graph capture on GB10). NOT required for
#                             single-node TP=1 — remove it in split-node deployments.
#                             (Brian on dgx-spark-cluster confirmed this distinction.)
# --enable-prefix-caching:   KV cache reuse for shared prefixes (system prompts, few-shot
#                             examples). Big win for chat/agent workloads.
# --block-size 128:           KV cache block granularity; 128 is optimal for GB10.
# --attention-backend flashinfer: Optimized attention kernel for GB10/Hopper architecture.
# --kv-cache-dtype fp8:       Store KV cache in FP8 instead of fp16. Saves ~40% KV memory
#                             with minimal quality impact on FP8/Qwen3 class models.
#                             Requires flashinfer attention backend (already set above).
# --enable-auto-tool-choice:  Enable native tool-calling / function-calling support.
#                             Required for structured tool use with compatible models.
# --tool-call-parser qwen3_coder: Use Qwen3-Coder tool-call format parser. Switch to
#                             "hermes" or "llama3_json" for other model families.
# --max-num-seqs 16:          Max concurrent sequences; tune based on available VRAM.
#                             Per-node overrides (node.env.*) can raise this for
#                             nodes with more headroom.
# --trust-remote-code:        Required by some HuggingFace models (Qwen3, etc.).
VLLM_EXTRA_ARGS="--enforce-eager --enable-prefix-caching --block-size 128 --attention-backend flashinfer --kv-cache-dtype fp8 --enable-auto-tool-choice --tool-call-parser qwen3_coder --max-num-seqs 16 --trust-remote-code"

# =============================================================================
# TRT-LLM Settings
# =============================================================================
# These apply when SPARK_ENGINE=trtllm
TRTLLM_PORT=8355
TRTLLM_MAX_BATCH_SIZE=4
TRTLLM_MAX_NUM_TOKENS=32768
TRTLLM_GPU_MEM_FRACTION=0.9
