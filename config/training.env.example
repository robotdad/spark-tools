# Spark Tools - Training Configuration
# Copy to ~/.config/spark-tools/training.env
# Or run: spark-train-setup

# =============================================================================
# Training Script Location
# =============================================================================
# Path to the training project directory on the local filesystem.
# Must contain train.py (or whatever your torchrun entry point is).
# This is generic — works with lampblack, open-instruct, or any torchrun project.
TRAINING_SCRIPT_DIR=/home/robotdad/repos/timemachine/lampblack

# =============================================================================
# Data and Checkpoints
# =============================================================================
# Directory containing tokenized data shards (must exist on BOTH nodes).
# Use spark-train-stage to sync data across nodes.
TRAINING_DATA_DIR=/mnt/nvme/training-data

# Directory for training checkpoints (written by the training script).
# spark-train-resume reads from here to find resumable checkpoints.
TRAINING_CHECKPOINT_DIR=/mnt/nvme/checkpoints

# =============================================================================
# Safety Limits
# =============================================================================
# Maximum memory for the training cgroup jail (systemd-run MemoryMax).
# Default 100G leaves ~28GB headroom per node for OS, SSH, and NCCL buffers.
# Format: systemd memory notation (e.g., 100G, 102400M)
TRAINING_MEMORY_MAX=100G

# Seconds to wait for a checkpoint save after SIGTERM before suggesting --immediate.
# Increase for very large models that take longer to serialize.
CHECKPOINT_TIMEOUT=120
